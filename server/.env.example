# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/venturonest

# Server Configuration
PORT=5000
NODE_ENV=development

# ImageKit Configuration
# Get these from your ImageKit dashboard: https://imagekit.io/dashboard
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key_here
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key_here
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id_here

# Example values (replace with your actual keys):
# IMAGEKIT_PUBLIC_KEY=public_abc123xyz
# IMAGEKIT_PRIVATE_KEY=private_def456uvw
# IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/myapp123